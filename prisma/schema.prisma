// Prisma schema for Doltsite
// PostgreSQL database (Supabase/Neon recommended)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User account model — CORE business logic
model Account {
  id            String   @id @default(cuid())
  email         String   @unique @db.VarChar(255)
  name          String   @db.VarChar(255)
  passwordHash  String   @db.Text

  // 🧱 1. SUBSCRIPTION TIER (determines limits & cost)
  // free → 3/day
  // basic → 10/day
  // standard → 200/month
  // premium → unlimited
  tier          String   @default("free") @db.VarChar(20)
  
  // 🧱 2. SUBSCRIPTION STATUS (is subscription valid?)
  // "active" = paying or free tier
  // "expired" = subscription ended, needs renewal
  // "cancelled" = user cancelled subscription
  subscriptionStatus String @default("active") @db.VarChar(20)

  // 🧱 3. GENERATION LIMITS (enforce "3 free then pay" logic)
  // For free/basic → daily limit
  // For standard → monthly limit
  // For premium → unlimited
  generationsUsed   Int      @default(0)        // Generations used in current period
  generationsLimit  Int      @default(3)        // Maximum allowed (set by tier)
  lastResetAt       DateTime @default(now())    // When limit was last reset (daily or monthly)

  // 🧱 4. SUBSCRIPTION VALIDITY
  // When does subscription expire?
  // null = free tier (no expiry)
  // future date = subscription active until this date
  // past date = subscription expired
  subscriptionExpiresAt DateTime?

  // 🧱 5. ACTIVITY TRACKING (optional but powerful)
  lastLoginAt       DateTime?                   // When user last logged in
  lastGenerationAt  DateTime?                   // When user last generated a website
  createdAt         DateTime @default(now())    // Account creation date
  updatedAt         DateTime @updatedAt

  // Relations
  payments          Payment[]
  generations       Generation[]

  @@index([email])                    // Fast lookup by email
  @@index([tier])                     // Find all users on each tier
  @@index([subscriptionStatus])       // Find expired subscriptions
  @@index([subscriptionExpiresAt])    // Find subscriptions expiring soon
  @@map("accounts")
}

// Payment/subscription record
model Payment {
  id            String   @id @default(cuid())
  accountId     String   @db.VarChar(255)
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Payment details
  amount        String   @db.VarChar(50)   // "20 GHS", "50 GHS", etc.
  tier          String   @db.VarChar(20)   // basic | standard | premium
  durationDays  Int      @default(30)      // How long subscription lasts

  // Payment status: pending | completed | failed
  status        String   @default("pending") @db.VarChar(20)
  
  // Payment reference
  reference     String?  @db.VarChar(255)  // MoMo transaction ID, etc.
  note          String?  @db.Text

  // When initiated and completed
  submittedAt   DateTime @default(now())
  completedAt   DateTime?

  @@index([accountId])
  @@index([status])
  @@map("payments")
}

// 🔥 GENERATION LOG — Track every website generated
// THIS is how you enforce limits like "3 free then pay"
model Generation {
  id            String   @id @default(cuid())
  accountId     String   @db.VarChar(255)
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // What was generated
  description   String   @db.Text           // User's prompt: "restaurant website"
  htmlOutput    String   @db.Text           // Generated HTML (store for redownload)
  
  // When was it generated (for monthly/daily reset logic)
  generatedAt   DateTime @default(now())
  
  // Did it count towards user's limit? (yes for paid, no for demo)
  countedTowardLimit Boolean @default(true)

  @@index([accountId])
  @@index([generatedAt])
  @@map("generations")
}

// Session cache (optional, for fast session lookups)
// Using PostgreSQL instead of Redis for reliability
model Session {
  id            String   @id @default(cuid())
  accountId     String   @db.VarChar(255)

  // JWT token and expiry
  token         String   @db.Text
  expiresAt     DateTime

  // For cleanup
  createdAt     DateTime @default(now())

  @@index([accountId])
  @@index([expiresAt])
  @@map("sessions")
}
